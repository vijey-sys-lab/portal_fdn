// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSuperAdmin() {
      return request.auth.token.email == "vijey.prasanna@devverse1.in";
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.status == "approved";
    }

    function isIntern() {
      return exists(/databases/$(database)/documents/interns/$(request.auth.uid))
        && get(/databases/$(database)/documents/interns/$(request.auth.uid)).data.status == "approved";
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // Admins collection
    match /admins/{adminId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || request.auth.uid == adminId || isAdmin());
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || request.auth.uid == adminId;
      allow delete: if isSuperAdmin();
    }

    // Interns collection
    match /interns/{internId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isAdmin() || request.auth.uid == internId);
      allow create: if isSuperAdmin() || isAdmin();
      allow update: if isSuperAdmin() || isAdmin() || request.auth.uid == internId;
      allow delete: if isSuperAdmin();
    }

    // Tasks collection
    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isSuperAdmin() || isAdmin();
      allow update: if isSuperAdmin() || isAdmin() || isIntern();
      allow delete: if isSuperAdmin() || isAdmin();
    }

    // Journals collection
    match /journals/{journalId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        isAdmin() ||
        request.auth.uid == resource.data.internId
      );
      allow create: if isAuthenticated() && isIntern();
      allow update: if isSuperAdmin() || isAdmin();
      allow delete: if isSuperAdmin();
    }

    // Reviews collection
    match /reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isSuperAdmin() || isAdmin();
      allow update: if isSuperAdmin() || isAdmin();
      allow delete: if isSuperAdmin();
    }
  }
}
